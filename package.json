{
    "name": "@noahtkeller/common-strings",
    "description": "The strings-source repository compiled for use within NodeJS ecosystem. Provides ESM and CJS bundles.",
    "version": "0.1.1",
    "scripts": {
        "build": "gulp",
        "clean": "gulp clean"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noahtkeller/node-common-strings.git"
    },
    "homepage": "https://github.com/noahtkeller/node-common-strings",
    "bugs": "https://github.com/noahtkeller/node-common-strings/issues",
    "author": {
        "name": "Noah Keller",
        "email": "noahtkeller@gmail.com",
        "url": "https://noahtkeller.github.io/"
    },
    "license": "MIT",
    "devDependencies": {
        "gulp": "^4.0.2",
        "mkdirp": "^1.0.4",
        "rimraf": "^3.0.2",
        "yaml": "^1.10.2"
    },
    "exports": {
        ".": {
            "require": "./cjs/index.js",
            "import": "./esm/index.mjs"
        },
        "./config": {
            "require": "./cjs/config.js",
            "import": "./esm/config.mjs"
        },
        "./config/secrets": {
            "require": "./cjs/config/secrets.js",
            "import": "./esm/config/secrets.mjs"
        },
        "./icon_sources": {
            "require": "./cjs/icon_sources.js",
            "import": "./esm/icon_sources.mjs"
        },
        "./system": {
            "require": "./cjs/system.js",
            "import": "./esm/system.mjs"
        },
        "./i18n/keys": {
            "require": "./cjs/i18n/keys.js",
            "import": "./esm/i18n/keys.mjs"
        },
        "./i18n/keys/errors": {
            "require": "./cjs/i18n/keys/errors.js",
            "import": "./esm/i18n/keys/errors.mjs"
        },
        "./i18n/keys/gh_pages": {
            "require": "./cjs/i18n/keys/gh_pages.js",
            "import": "./esm/i18n/keys/gh_pages.mjs"
        },
        "./i18n/keys/system": {
            "require": "./cjs/i18n/keys/system.js",
            "import": "./esm/i18n/keys/system.mjs"
        },
        "./i18n/bundles": {
            "require": "./cjs/i18n/bundles.js",
            "import": "./esm/i18n/bundles.mjs"
        },
        "./i18n/bundles/errors": {
            "require": "./cjs/i18n/bundles/errors.js",
            "import": "./esm/i18n/bundles/errors.mjs"
        },
        "./i18n/bundles/gh_pages": {
            "require": "./cjs/i18n/bundles/gh_pages.js",
            "import": "./esm/i18n/bundles/gh_pages.mjs"
        },
        "./i18n/bundles/system": {
            "require": "./cjs/i18n/bundles/system.js",
            "import": "./esm/i18n/bundles/system.mjs"
        }
    }
}
